### Step 4: Extract `handleDefect()` Factory and Replace 4 Blocks

**Insert after the `soulLoadError()` helper** (or after `filterByLevel` — any module-level position works).

**Add new helper:**

```typescript
/**
 * Creates a catchAllDefect handler that logs the defect.
 * - Without fallback: logs the defect then fails with SoulLoadError.
 * - With fallback: logs the defect then returns the fallback value (no failure).
 */
function handleDefect(message: string): <A>(defect: unknown) => Effect.Effect<A, SoulLoadError>;
function handleDefect<T>(
  message: string,
  fallback: T,
): <A>(defect: unknown) => Effect.Effect<T | A, never>;
function handleDefect<T>(message: string, fallback?: T) {
  return <A>(defect: unknown): Effect.Effect<A | T, SoulLoadError | never> =>
    Effect.gen(function* () {
      yield* Effect.logError(`[loader] ${message}`, Cause.pretty(Cause.die(defect)));
      if (fallback !== undefined) {
        return fallback as T;
      }
      return yield* Effect.fail(soulLoadError(message)) as unknown as A;
    });
}
```

**Replace site 1 — `loadSoul` catchAllDefect (lines 263–274):**

```typescript
        Effect.catchAllDefect(handleDefect(`Defect loading soul "${soulName}"`)),
```

**Replace site 2 — `loadAllSouls` per-soul catchAllDefect (lines 314–324):**

```typescript
              Effect.catchAllDefect(handleDefect(`Defect loading soul "${entry}"`, null as null)),
```

**Replace site 3 — `loadAllSouls` outer catchAllDefect (lines 352–365):**

```typescript
        Effect.catchAllDefect(handleDefect("Defect loading all souls")),
```

**Replace site 4 — `getSoul` catchAllDefect (lines 389–397):**

```typescript
