## 5. Backward-Compat Shim Strategy

### `load` shim (cache-first)

```typescript
const load = (soulPath: string, level: number = 2) => {
  return Effect.gen(function* () {
    // Fast path: check cache first
    const maybeCached = yield* getSoul(soulPath, level).pipe(
      Effect.catchAll(() => Effect.succeed(null as SoulManifest | null)),
    );
    if (maybeCached) return maybeCached;

    // Slow path: load from disk
    const manifest = yield* loadSoul(soulPath);
    return filterByLevel(manifest, level);
  }).pipe(
    // Error remapping (same as current load)
    Effect.catchTags({
      SoulNotFoundError: (e) =>
        Effect.gen(function* () {
          yield* Effect.logDebug(`[loader] Soul not found: ${soulPath}`);
          const offers = yield* getSoulOffers(e.soulPath);
          const message = offers
            ? formatSoulOffers(e.soulPath, offers)
            : `Soul "${soulPath}" not found.`;
          return yield* Effect.fail(
            new SoulLoadError({ message, soulName: e.soulPath, offers: offers ?? undefined }),
          );
        }),
      ManifestParseError: (e) =>
        Effect.fail(
          new SoulLoadError({
            message: `Error parsing soul manifest: ${getErrorMessage(e.cause)}`,
            cause: e.cause,
          }),
        ),
      FileSystemError: (e) =>
        Effect.fail(
          new SoulLoadError({
            message: `File system error: ${getErrorMessage(e.cause)}`,
            cause: e.cause,
          }),
        ),
    }),
    Effect.catchAllCause((cause) => {
      if (Cause.isDieType(cause)) {
        yield * Effect.logError(`[loader] Defect loading soul "${soulPath}"`, Cause.pretty(cause));
      } else {
        yield *
          Effect.logWarning(
            `[loader] Unexpected error loading soul "${soulPath}"`,
            Cause.pretty(cause),
          );
      }
      return Effect.fail(
        new SoulLoadError({ message: "Error loading soul: Unexpected error", cause }),
      );
    }),
  );
};
```

### `getAllSouls` shim (disk scan, unchanged logic)

```typescript
const getAllSouls = () => {
  return getAllSoulsInternal().pipe(
    Effect.catchTags({
      NoSoulsFoundError: () => {
        yield * Effect.logDebug("[loader] No souls found in any search path");
        return Effect.fail(
          new SoulLoadError({
            message: "No souls found. Create a souls/ directory with soul.json files.",
          }),
        );
      },
    }),
    Effect.catchAllCause((cause) => {
      if (Cause.isDieType(cause)) {
        yield * Effect.logError(`[loader] Defect listing souls: ${Cause.pretty(cause)}`);
      } else {
        yield *
          Effect.logWarning(`[loader] Unexpected error listing souls: ${Cause.pretty(cause)}`);
      }
      return Effect.fail(
        new SoulLoadError({ message: "Error listing souls: Unexpected error", cause }),
      );
    }),
  );
};
```

### `enumerateSouls` shim (delegates to `loadAllSouls` at level 1)

```typescript
const enumerateSouls = () => {
  return Effect.gen(function* () {
    const manifests = yield* loadAllSouls(1).pipe(
      Effect.catchAll(() => Effect.succeed([] as SoulManifest[])),
    );
    return manifests.map((m) => ({
      _tag: "loaded" as const,
      name: m.name,
      manifest: m,
    }));
  });
};
```

**Note:** `loadAllSouls(1)` calls `loadSoul(name, 1)` for each discovered soul — one `soul.json` read per soul. This matches the current I/O profile (level 1 only) while populating the cache with level-1 manifests for future `getSoul` calls.

### `findMatchingSouls` shim (unchanged logic, Effect.log\* migration)

```typescript
const findMatchingSouls = (pattern: RegExp) => {
  return findMatchingSoulsInternal(pattern).pipe(
    Effect.catchAllCause((cause) => {
      yield *
        Effect.logWarning(
          `[loader] Error searching souls with pattern ${pattern}: ${Cause.pretty(cause)}`,
        );
      return Effect.succeed([] as string[]);
    }),
  );
};
```

