import type { FileSystem } from "@effect/platform";
import { Effect } from "effect";
import { FileSystemError, ManifestParseError } from "../types"; // Error classes defined in TP-002 Step 8

/**
 * Expand ~ to the user's home directory.
 * This is a sync boundary function — NOT an Effect.
 * Must be called before passing paths to @effect/platform FileSystem methods.
 */
export function expandHome(p: string): string {
  const home = process.env.HOME || process.env.USERPROFILE || "/home/user";
  if (p === "~") return home;
  if (p.startsWith("~/")) return `${home}/${p.slice(2)}`;
  return p;
}

/**
 * Find subdirectories under `basePath` that contain a `soul.json` file.
 * Returns directory names (not full paths).
 */
export function findDirectories(
  fs: FileSystem,
  basePath: string,
): Effect.Effect<string[], FileSystemError> {
  return Effect.gen(function* () {
    const resolvedPath = expandHome(basePath);
    const exists = yield* fs.exists(resolvedPath);
    if (!exists) return [];

    const entries = yield* fs.readDirectory(resolvedPath);
    const dirs: string[] = [];

    for (const entry of entries) {
      // For each entry, check if it's a directory containing soul.json
      const soulJsonPath = `${resolvedPath}/${entry}/soul.json`;
      const hasSoulJson = yield* fs.exists(soulJsonPath);
      if (hasSoulJson) {
        dirs.push(entry);
      }
    }

    return dirs;
  }).pipe(Effect.catchAll((cause) => Effect.fail(new FileSystemError({ path: basePath, cause }))));
}

/**
 * Read and parse a JSON file, returning the typed result.
 */
export function readJsonFile<T>(
  fs: FileSystem,
  path: string,
): Effect.Effect<T, ManifestParseError | FileSystemError> {
  return Effect.gen(function* () {
    const content = yield* fs.readFileString(path);
    try {
      return JSON.parse(content) as T;
    } catch (cause) {
      return yield* Effect.fail(new ManifestParseError({ path, cause }));
    }
  }).pipe(
    Effect.catchAll((cause) => {
      if (cause instanceof ManifestParseError) return Effect.fail(cause);
      return Effect.fail(new FileSystemError({ path, cause }));
    }),
  );
}

/**
 * Read a text file, returning its content as a string.
 */
export function readTextFile(fs: FileSystem, path: string): Effect.Effect<string, FileSystemError> {
  return Effect.gen(function* () {
    return yield* fs.readFileString(path);
  }).pipe(Effect.catchAll((cause) => Effect.fail(new FileSystemError({ path, cause }))));
}
```

