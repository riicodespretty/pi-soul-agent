  Effect.catchTag("ManifestParseError", (e) => Effect.succeed(errorResponse)),
  Effect.catchTag("FileSystemError", (e) => Effect.succeed(errorResponse)),
  Effect.catchAllCause((cause) => Effect.succeed(errorResponse)),
)
