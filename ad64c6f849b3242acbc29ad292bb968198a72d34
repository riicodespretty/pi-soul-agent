import { Effect, Ref, Option } from "effect";
import { FileSystem } from "@effect/platform";
import type { SoulManifest, SoulLoadError } from "./types";
import { SoulNotFoundError, ManifestParseError } from "./types";
import { expandHome, readJsonFile, readTextFile } from "./services/soul-fs";

/** Soul search paths (with tilde — expanded at runtime) */
const SOUL_SEARCH_PATHS = [
  "~/.pi/agent/souls",
  "~/.openclaw/souls/clawsouls",
  ".pi/souls",
  "./souls",
] as const;

export class SoulSpecLoader extends Effect.Service<SoulSpecLoader>()("app/SoulSpecLoader", {
  effect: Effect.gen(function* () {
    const fs = yield* FileSystem;
    const cache = yield* Ref.make<Map<string, SoulManifest>>(new Map());

    /**
     * Resolve a soul name to its manifest directory path.
     * Supports partial matching: "dev" matches "developer" if unique.
     */
    const resolveSoulPath = (soulName: string): Effect.Effect<string, SoulNotFoundError> => {
      return Effect.gen(function* () {
        // Check exact match first
        for (const base of SOUL_SEARCH_PATHS) {
          const resolvedBase = expandHome(base);
          const exactPath = `${resolvedBase}/${soulName}/soul.json`;
          const exists = yield* fs.exists(exactPath);
          if (exists) {
            return `${resolvedBase}/${soulName}`;
          }
        }

        // Partial matching — scan all souls dirs
        const allSouls = yield* getAllSouls();
        const pattern = new RegExp(soulName, "i");
        const matches = allSouls.filter((s) => pattern.test(s));

        if (matches.length === 0) {
          return yield* Effect.fail(new SoulNotFoundError({ soulPath: soulName }));
        }

        // Return first match (caller can use findMatching for disambiguation)
        return matches[0];
      });
    };

    /**
     * Load a soul manifest with progressive disclosure.
     * Level 1: metadata only (soul.json)
     * Level 2: include identity, style, heartbeat content
     * Level 3: include all content (agents, user_template, examples)
     */
    const load = (
      soulPath: string,
      level: number = 2,
    ): Effect.Effect<SoulManifest, SoulLoadError> => {
      return Effect.gen(function* () {
        // Check cache
        const currentCache = yield* Ref.get(cache);
        const cached = currentCache.get(soulPath);
        if (cached && level <= 2) {
          return cached;
        }

        // Resolve path
        const resolvedDir = yield* resolveSoulPath(soulPath);

        // Read manifest
        const manifestPath = `${resolvedDir}/soul.json`;
        const manifest = yield* readJsonFile<SoulManifest>(fs, manifestPath);

        // Set resolved path
        manifest.soul_path = resolvedDir;

        // Progressive disclosure — load optional files
        if (level >= 2 && manifest.files) {
          const files = manifest.files;
          if (files.identity) {
            manifest.identity_content = yield* readTextFile(
              fs,
              `${resolvedDir}/${files.identity}`,
            ).pipe(Effect.catchAll(() => Effect.succeed(undefined)));
          }
          if (files.style) {
            manifest.style_content = yield* readTextFile(fs, `${resolvedDir}/${files.style}`).pipe(
              Effect.catchAll(() => Effect.succeed(undefined)),
            );
          }
          if (files.heartbeat) {
            manifest.heartbeat_content = yield* readTextFile(
              fs,
              `${resolvedDir}/${files.heartbeat}`,
            ).pipe(Effect.catchAll(() => Effect.succeed(undefined)));
          }
        }

        if (level >= 3 && manifest.files) {
          const files = manifest.files;
          if (files.agents) {
            manifest.agents_content = yield* readTextFile(
              fs,
              `${resolvedDir}/${files.agents}`,
            ).pipe(Effect.catchAll(() => Effect.succeed(undefined)));
          }
          if (files.user_template) {
            manifest.user_template_content = yield* readTextFile(
              fs,
              `${resolvedDir}/${files.user_template}`,
            ).pipe(Effect.catchAll(() => Effect.succeed(undefined)));
          }
          if (manifest.examples?.good) {
            manifest.examples_good_content = yield* readTextFile(
              fs,
              `${resolvedDir}/${manifest.examples.good}`,
            ).pipe(Effect.catchAll(() => Effect.succeed(undefined)));
          }
          if (manifest.examples?.bad) {
            manifest.examples_bad_content = yield* readTextFile(
              fs,
              `${resolvedDir}/${manifest.examples.bad}`,
            ).pipe(Effect.catchAll(() => Effect.succeed(undefined)));
          }
        }

        // Update cache
        yield* Ref.update(cache, (m) => new Map(m).set(soulPath, manifest));

        return manifest;
      });
    };

    /**
     * List all available souls (directory names that contain soul.json).
     */
    const getAllSouls = (): Effect.Effect<string[], never> => {
      return Effect.gen(function* () {
        const seen = new Set<string>();
        const souls: string[] = [];

        for (const base of SOUL_SEARCH_PATHS) {
          try {
            // Use findDirectories from soul-fs
            const { findDirectories } = yield* Effect.sync(() => import("./services/soul-fs"));
            // This is a simpler inline version:
            const resolvedBase = expandHome(base);
            const exists = yield* fs.exists(resolvedBase);
            if (!exists) continue;

            const entries = yield* fs.readDirectory(resolvedBase);
            for (const entry of entries) {
              if (seen.has(entry)) continue;
              const soulJsonPath = `${resolvedBase}/${entry}/soul.json`;
              const hasSoul = yield* fs.exists(soulJsonPath);
              if (hasSoul) {
                seen.add(entry);
                souls.push(entry);
              }
            }
          } catch {
            // Skip inaccessible directories silently (matching ref impl)
            continue;
          }
        }

        return souls;
      });
    };

    /**
     * Find souls matching a regex pattern.
     */
    const findMatchingSouls = (pattern: RegExp): Effect.Effect<string[], never> => {
      return Effect.gen(function* () {
        const all = yield* getAllSouls();
        return all.filter((s) => pattern.test(s));
      });
    };

    return {
      load,
      getAllSouls,
      findMatchingSouls,
      resolveSoulPath,
    } as const;
  }),
  dependencies: [], // FileSystem provided externally via NodeFileSystem.layer
}) {}
```

**Important notes for this file:**

- `Effect.Service` returns the Tag automatically; access via `SoulSpecLoader.Default` for the layer
- The `cache` is a `Ref<Map<string, SoulManifest>>` — mutable state managed via immutable Map updates
- `resolveSoulPath` searches all 4 paths in order, supports partial matching with regex
- File reads use `.pipe(Effect.catchAll(() => Effect.succeed(undefined)))` — optional files failing to load returns `undefined` instead of error
- Avoid circular imports: don't import from `./system-prompt.ts` or `./persistence.ts` here

